# Required Telegram settings
BOT_TOKEN=123456:replace-me
BOT_USERNAME=wivio_bot
UPLOAD_CHAT_ID=-1001234567890

# Runtime mode
BOT_MODE=polling
HOST=0.0.0.0
PORT=8080
HEALTHCHECK_PATH=/healthz

# Storage
DATABASE_PATH=./data/bot.sqlite3
DOWNLOADS_DIR=./downloads
LOGS_DIR=./logs

# Download and inline behavior
MAX_VIDEO_SIZE_MB=49
INLINE_DOWNLOAD_TIMEOUT=45
INLINE_READY_WAIT_SECONDS=12
INLINE_CACHE_TIME=86400
DOWNLOAD_RETRIES=2
UPLOAD_RETRIES=2

# Cache limits
MAX_CACHED_VIDEOS=5000
CACHE_TRIM_TO_VIDEOS=4500
TEMP_FILE_TTL_SECONDS=3600
CLEANUP_INTERVAL_SECONDS=900

# Rate limits
RATE_LIMIT_PER_MINUTE=6
COOLDOWN_SECONDS=0

# Welcome media
WELCOME_FORWARD_CHAT_ID=
WELCOME_FORWARD_MESSAGE_ID=
WELCOME_ANIMATION_URL=
WELCOME_ANIMATION_PATH=
WELCOME_ANIMATION_FILE_ID=
WELCOME_VIDEO_FILE_ID=

# Admins
ADMIN_USER_IDS=

# Logging and alerts
LOG_LEVEL=INFO
ALERTS_ENABLED=false
ALERT_BOT_TOKEN=
ALERT_CHAT_ID=
ALERT_MESSAGE_THREAD_ID=
ALERT_LEVEL=ERROR
ALERT_SSL_VERIFY=true

# Webhook mode, leave empty for polling
WEBHOOK_URL=
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=

DEBUG=false
